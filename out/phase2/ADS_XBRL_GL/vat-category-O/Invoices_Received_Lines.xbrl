    <gl-cor:entryHeader>
      <gl-cor:entryDetail>
        <gl-cor:lineNumber contextRef="now">1</gl-cor:lineNumber>
        <gl-cor:amount contextRef="now" decimals="2" unitRef="SEK">3200.00</gl-cor:amount>
        <gl-muc:amountCurrency contextRef="now">SEK</gl-muc:amountCurrency>
        <gl-cor:documentNumber contextRef="now">Vat-O</gl-cor:documentNumber>
