        <gl-bus:measurable>
          <gl-bus:measurableID contextRef="now">RT3000</gl-bus:measurableID>
          <gl-bus:measurableDescription contextRef="now">Road tax</gl-bus:measurableDescription>
          <gl-bus:measurableQuantity contextRef="now" decimals="2" unitRef="EA">1</gl-bus:measurableQuantity>
          <gl-bus:measurableUnitOfMeasure contextRef="now">EA</gl-bus:measurableUnitOfMeasure>
          <gl-bus:measurableCostPerUnit contextRef="now" decimals="2" unitRef="SEK">3200.00</gl-bus:measurableCostPerUnit>
