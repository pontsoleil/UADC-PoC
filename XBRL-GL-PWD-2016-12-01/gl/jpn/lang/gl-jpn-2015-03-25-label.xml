/crediitAccount/crediitAccountMainID 1000 
/crediitAccount/crediitAccountMainDescription Cash 
/crediitAccount/crediitAccountSub/crediitAccountSubID 4783HG 
/crediitAccount/crediitAccountSub/crediitAccountSubDescription Department 
/crediitAccount/crediitAccountSub/crediitAccountSubID QOWI 
/crediitAccount/crediitAccountSub/crediitAccountSubDescription Branch 
/crediitAccount/crediitAccountSub/crediitAccountSubID 192837 
/crediitAccount/crediitAccountSub/crediitAccountSubDescription Division 
